# Copy to .env and fill in. Used by the `uploader` service.

# --- Required ---
S3_BUCKET=my-btc-data

# --- Hetzner Object Storage (S3-compatible) ---
# Endpoint matches your bucket's location: fsn1 / nbg1 / hel1
S3_ENDPOINT_URL=https://fsn1.your-objectstorage.com
S3_REGION=fsn1

# Credentials are NOT set here. They are provided via a Docker secret —
# copy secrets/s3_credentials.example to secrets/s3_credentials and fill it in.

# --- Optional ---
# Key prefix inside the bucket, e.g. btcusdt/depth5_tick_20260630.csv
S3_PREFIX=btcusdt
# Set to "true" if your provider needs path-style addressing
S3_FORCE_PATH_STYLE=false
# Seconds between sync passes
UPLOAD_INTERVAL_SECS=300
# Delete local finalized files older than this many days (after they're in the
# bucket). 0 or unset disables local pruning.
RETENTION_DAYS=7
